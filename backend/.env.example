# Copie ce fichier en ".env" et remplis au moins une clé.
# Toutes les clés ci-dessous sont gratuites, sans carte bancaire.

# Gemini : https://aistudio.google.com (qualité, mais ~20 req/jour/modèle en gratuit)
GEMINI_API_KEY=
# Cerebras : https://cloud.cerebras.ai (1M tokens/jour gratuits)
CEREBRAS_API_KEY=
# Groq : https://console.groq.com/keys (14 400 req/jour sur llama 8b)
GROQ_API_KEY=
# Mistral : https://console.mistral.ai (tier Experiment, 2 req/min)
MISTRAL_API_KEY=

# Chaîne de bascule : entrées "fournisseur/modèle" essayées dans l'ordre.
# Les fournisseurs sans clé sont sautés automatiquement au démarrage.
LLM_CHAIN=gemini/gemini-3.5-flash,gemini/gemini-3.1-flash-lite,gemini/gemini-3-flash-preview,gemini/gemini-2.5-flash,gemini/gemini-2.5-flash-lite,cerebras/gpt-oss-120b,cerebras/zai-glm-4.7,groq/llama-3.3-70b-versatile,groq/llama-3.1-8b-instant,mistral/mistral-small-latest
